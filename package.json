{
  "name": "claw",
  "version": "0.1.0",
  "private": true,
  "description": "Deploy OpenClaw in 1 minute. No terminal. No API keys.",
  "workspaces": [
    "backend",
    "pool-worker",
    "shared"
  ],
  "scripts": {
    "dev:backend": "cd backend && npm run dev",
    "dev:worker": "cd pool-worker && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:worker\"",
    "build": "npm run build --workspaces",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "canvas": "^3.2.1",
    "fastify-raw-body": "^5.0.0"
  }
}
